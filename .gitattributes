# Normalize text files across platforms
* text=auto

# Source
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary artifacts
*.pth binary
*.pt binary
*.png binary
*.jpg binary
*.jpeg binary
*.mp4 binary

